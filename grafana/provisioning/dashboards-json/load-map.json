{
  "title": "SmartGrid — Load Map",
  "uid": "smartgrid-load-map",
  "tags": ["smartgrid", "energy"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "2023-01-01T00:00:00Z",
    "to": "2023-01-22T00:00:00Z"
  },
  "panels": [
    {
      "id": 10,
      "title": "Demo Readings",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "TimescaleDB",
          "rawSql": "SELECT COUNT(*) AS readings FROM meter_readings WHERE $__timeFilter(time)",
          "format": "table"
        }
      ]
    },
    {
      "id": 11,
      "title": "Forecast Rows",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "TimescaleDB",
          "rawSql": "SELECT COUNT(*) AS forecasts FROM meter_predictions WHERE $__timeFilter(time)",
          "format": "table"
        }
      ]
    },
    {
      "id": 12,
      "title": "Anomaly Events",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "TimescaleDB",
          "rawSql": "SELECT COUNT(*) AS anomalies FROM anomaly_events WHERE $__timeFilter(reading_time)",
          "format": "table"
        }
      ]
    },
    {
      "id": 13,
      "title": "Monitoring Targets UP",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "TimescaleDB",
          "rawSql": "SELECT 3 AS targets_up",
          "format": "table"
        }
      ]
    },
    {
      "id": 1,
      "title": "Total Grid Consumption (kWh/h)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": "TimescaleDB",
          "rawSql": "SELECT bucket AS time, SUM(kwh_total) AS kwh FROM meter_hourly WHERE $__timeFilter(bucket) GROUP BY bucket ORDER BY bucket",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 2,
      "title": "Anomaly Events",
      "type": "table",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "TimescaleDB",
          "rawSql": "SELECT reading_time AS time, meter_id, kwh_actual, kwh_expected, severity FROM anomaly_events WHERE $__timeFilter(reading_time) ORDER BY reading_time DESC LIMIT 50",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "title": "Consumption by Source",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "TimescaleDB",
          "rawSql": "SELECT COALESCE(source, 'unknown') AS source, SUM(kwh) AS kwh FROM meter_readings WHERE $__timeFilter(time) GROUP BY COALESCE(source, 'unknown') ORDER BY source",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "title": "Forecast vs Actual",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": "TimescaleDB",
          "rawSql": "SELECT time, SUM(kwh) AS actual FROM meter_readings WHERE $__timeFilter(time) GROUP BY time ORDER BY time",
          "format": "time_series",
          "legendFormat": "Actual"
        },
        {
          "datasource": "TimescaleDB",
          "rawSql": "SELECT time, SUM(kwh_pred) AS predicted FROM meter_predictions WHERE $__timeFilter(time) GROUP BY time ORDER BY time",
          "format": "time_series",
          "legendFormat": "Predicted"
        }
      ]
    },
    {
      "id": 5,
      "title": "Prometheus Infrastructure Metrics",
      "type": "table",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "timeFrom": "5m",
      "targets": [
        {
          "datasource": "Prometheus",
          "refId": "A",
          "expr": "up",
          "format": "table",
          "instant": true,
          "legendFormat": "{{job}}"
        },
        {
          "datasource": "Prometheus",
          "refId": "B",
          "expr": "scrape_duration_seconds",
          "format": "table",
          "instant": true,
          "legendFormat": "{{job}} scrape"
        }
      ]
    }
  ]
}
